# ============================================================================
#  Секреты API. Скопируй в .env и заполни реальными ключами:
#      cp .env.example .env
#  .env в .gitignore и НИКОГДА не коммитится.
#
#  Права ключей на старте: ТОЛЬКО торговля фьючерсами, БЕЗ вывода средств.
#  Где поддерживается — привязать ключ к IP сервера (whitelist). (§1)
# ============================================================================

# --- Binance ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Bybit ---
BYBIT_API_KEY=
BYBIT_API_SECRET=

# --- OKX (требует passphrase) ---
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSWORD=

# --- Gate ---
GATE_API_KEY=
GATE_API_SECRET=

# --- Bitget (требует passphrase) ---
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSWORD=
